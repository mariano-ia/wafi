# ───────── Wafi · variables de entorno (copiá a .env y completá) ─────────
# El .env real está en .gitignore. NUNCA pongas secretos reales en este .example
# (se commitea a GitHub). Los secretos van en product/.env.

# Supabase (proyecto: elpantano / ajqjicwuqbxpgkrrnryn — schema wafi)
VITE_SUPABASE_URL=https://ajqjicwuqbxpgkrrnryn.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_PCi1fINjoAxKD6VtvNs3Lg_6NHjBs2C
# Personal Access Token para el CLI/Management API (va en .env). Da autonomía a la IA.
SUPABASE_ACCESS_TOKEN=__PONER_EN_.env__
# Solo backend / Edge Functions (va en .env, NUNCA acá):
SUPABASE_SERVICE_ROLE_KEY=__PONER_EN_.env__

# Mercado Pago (suscripción del comercio) — el ACCESS_TOKEN es secreto: va en .env
MP_ACCESS_TOKEN=__PONER_EN_.env__
MP_PUBLIC_KEY=__PONER_EN_.env__
MP_WEBHOOK_SECRET=__PONER_EN_.env__

# Login del cliente — OTP por SMS (Supabase Auth + Twilio Verify).
# WhatsApp = futuro: se agrega como canal en el MISMO Verify Service, sin tocar código.
TWILIO_ACCOUNT_SID=__PONER_EN_.env__
TWILIO_AUTH_TOKEN=__PONER_EN_.env__
TWILIO_VERIFY_SERVICE_SID=__PONER_EN_.env__

# Anti-bot / email
TURNSTILE_SITE_KEY=__PONER_EN_.env__
TURNSTILE_SECRET_KEY=__PONER_EN_.env__
RESEND_API_KEY=__PONER_EN_.env__

# Vercel (deploy autónomo vía REST API)
VERCEL_TOKEN=__PONER_EN_.env__

# Apple / Google Wallet (MVP-1, no urgente)
APPLE_PASS_TYPE_ID=__PONER_EN_.env__
APPLE_TEAM_ID=__PONER_EN_.env__
GOOGLE_WALLET_ISSUER_ID=__PONER_EN_.env__
